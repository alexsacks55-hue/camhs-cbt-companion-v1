# Copy this file to .env and fill in values before running locally.
# Never commit .env to source control.

# ── Backend ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Azure Database for PostgreSQL in UK South)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/camhs_cbt?schema=public"

# JWT signing secret — use a long random string in production
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Backend server
PORT=3001
NODE_ENV="development"

# CORS — frontend origin
CORS_ORIGIN="http://localhost:5173"

# ── Frontend ──────────────────────────────────────────────────────────────────

# Backend API base URL (used by Vite at build time via VITE_ prefix)
VITE_API_BASE_URL="http://localhost:3001/api"
VITE_APP_ENV="development"
