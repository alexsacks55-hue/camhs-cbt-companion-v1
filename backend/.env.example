# Backend environment — copy to .env for local development.

# ── Database ──────────────────────────────────────────────────────────────────
# Azure Database for PostgreSQL — UK South
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/camhs_cbt?sslmode=require"

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET="replace-with-a-long-random-secret-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
BCRYPT_ROUNDS="12"

# ── Server ────────────────────────────────────────────────────────────────────
PORT="3001"
NODE_ENV="development"

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN="http://localhost:5173"

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"
AUTH_RATE_LIMIT_MAX="5"
